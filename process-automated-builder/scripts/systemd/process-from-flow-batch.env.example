# Copy to: ~/.config/process-from-flow-batch/env
# Then edit values as needed.
# API keys / MCP endpoints are loaded from ~/.openclaw/.env by default service unit.

FLOW_DIR=/home/huimin/.openclaw/workspace/flow_batch/flow
STATE_PATH=/home/huimin/.openclaw/workspace/flow_batch/daemon_state/batch_state.json
LOG_DIR=/home/huimin/.openclaw/workspace/flow_batch/daemon_state/batch_logs

WORKERS=3
OPERATION=produce
MAX_ATTEMPTS=6
POLL_SECONDS=5
HEARTBEAT_SECONDS=30
# Increase this for long stage-7 runs to reduce false stall retries.
STALL_TIMEOUT_SECONDS=1800
